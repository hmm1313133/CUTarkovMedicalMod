    <Copy SourceFiles="$(OutDir)Framework\Assets\pnb.png" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\pnb.png')" />
    <Copy SourceFiles="$(OutDir)Framework\Assets\pnb.webp" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\pnb.webp')" />
