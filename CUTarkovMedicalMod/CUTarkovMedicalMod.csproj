    <Copy SourceFiles="$(OutDir)Framework\Assets\2a2btg.png" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\2a2btg.png')" />
