    <Copy SourceFiles="$(OutDir)Framework\Assets\propital.webp" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\propital.webp')" />
    <Copy SourceFiles="$(OutDir)Framework\Assets\sj6.png" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\sj6.png')" />
