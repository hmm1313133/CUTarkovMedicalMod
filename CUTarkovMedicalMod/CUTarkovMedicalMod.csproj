    <Copy SourceFiles="$(OutDir)Framework\Assets\mule.png" DestinationFolder="$(BepInExDir)/plugins/$(PluginDirName)/Framework/Assets" Condition="Exists('$(OutDir)Framework\Assets\mule.png')" />
