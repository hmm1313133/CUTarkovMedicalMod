# Ignore everything by default; only the mod project itself is tracked.
# 用白名单方式确保只推送 CUTarkovMedicalMod 本身的文件。

*

# 项目解决方案与说明
!.gitignore
!README.md
!CasualtiesUnknownTarkovMedicalMod.sln

# 构建路径配置（csproj 引用，构建/部署所需）
!vars.targets
!vars.local.targets.example

# 本地游戏路径覆盖（每开发者私有，不纳入版本控制）
vars.local.targets

# 模组源码与资产
!CUTarkovMedicalMod/
!CUTarkovMedicalMod/**

# 发布包与描述文件
!Release/
!Release/*.txt
!Release/*.md

# 打包脚本
!scripts/
!scripts/**

# 仍然排除构建产物
CUTarkovMedicalMod/bin/
CUTarkovMedicalMod/obj/
Release/*.zip
